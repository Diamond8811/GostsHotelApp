<Page x:Class="GostsHotelApp.Pages.MyBookingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GostsHotelApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Мои бронирования" Background="#0F0F0F">
    <Page.Resources>
        <local:CancelVisibleConverter x:Key="CancelVisibleConverter"/>
    </Page.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="📅 Мои бронирования" FontSize="28" FontWeight="Bold" Foreground="#708090" Margin="0,0,0,20"/>
        <DataGrid x:Name="dgBookings" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding Rooms.RoomNumber}"/>
                <DataGridTextColumn Header="Заезд" Binding="{Binding CheckInDate, StringFormat=d}"/>
                <DataGridTextColumn Header="Выезд" Binding="{Binding CheckOutDate, StringFormat=d}"/>
                <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalPrice}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
                <DataGridTemplateColumn Header="Действия">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Отменить" Tag="{Binding BookingID}" Click="CancelBooking_Click" 
                                        Visibility="{Binding Status, Converter={StaticResource CancelVisibleConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
