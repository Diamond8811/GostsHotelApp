<Page x:Class="GostsHotelApp.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GostsHotelApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Профиль" Background="#0F0F0F">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="👤 Мой профиль" FontSize="28" FontWeight="Bold" Foreground="#708090" Margin="0,0,0,20"/>
        <TextBlock Grid.Row="1" Text="Логин:"/>
        <TextBlock x:Name="tbLogin" Grid.Row="2" Margin="0,5"/>

        <TextBlock Grid.Row="3" Text="Имя призрака:"/>
        <TextBox x:Name="txtGhostName" Grid.Row="4" Margin="0,5"/>

        <TextBlock Grid.Row="5" Text="Год упокоения:"/>
        <TextBox x:Name="txtYear" Grid.Row="6" Margin="0,5"/>

        <TextBlock Grid.Row="7" Text="Уровень прозрачности (0-100):"/>
        <TextBox x:Name="txtTransparency" Grid.Row="8" Margin="0,5"/>

        <TextBlock Grid.Row="9" Text="Новый пароль (оставьте пустым, чтобы не менять):"/>
        <PasswordBox x:Name="txtNewPassword" Grid.Row="10" Margin="0,5"/>

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
            <Button x:Name="btnSave" Content="Сохранить изменения" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Page>